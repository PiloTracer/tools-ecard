{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://ecards_user:ecards_dev_password@127.0.0.1:7432/ecards_db"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "-y",
        "@sherifbutt/shadcn-ui-mcp-server"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "local-memory-mcp",
        "--mcp"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ]
    },
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-fetch-typescript"
      ]
    }
  }
}
