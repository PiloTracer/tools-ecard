# E-Cards / tools-ecards — monorepo environment (line-aligned; do not reorder)
# Used by: docker-compose.dev.yml | docker-compose.prd.yml | bin/start.sh
# Compare: .env vs .env.dev.example vs .env.prd vs .env.prd.example (values differ; keys+order must match)
#

# ============================================================================
# COMPOSE & RUNTIME
# ============================================================================
COMPOSE_PROJECT_NAME=tools-ecards-prd
NODE_ENV=production

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL (Normalized Database)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=7432
POSTGRES_DB=ecards_db
POSTGRES_USER=ecards_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql://ecards_user:CHANGE_ME_DB_PASSWORD@postgres:5432/ecards_db

# Cassandra (Canonical Event Store)
CASSANDRA_CLUSTER_NAME=ecards_cluster
CASSANDRA_HOSTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_NATIVE_PORT_HOST=7042
CASSANDRA_THRIFT_PORT_HOST=7160
CASSANDRA_KEYSPACE=ecards_canonical
CASSANDRA_DC=dc1
CASSANDRA_RACK=rack1
CASSANDRA_ENDPOINT_SNITCH=GossipingPropertyFileSnitch
CASSANDRA_NUM_TOKENS=256
CASSANDRA_JMX_PORT=7199
# Cassandra JVM Memory Settings (dev image default heap can be large; tune in production)
CASSANDRA_MAX_HEAP_SIZE=2G
CASSANDRA_HEAP_NEWSIZE=512M
CASSANDRA_JVM_OPTS=-XX:MaxDirectMemorySize=1G

# Redis (Cache & Job Queue)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=7379
REDIS_PASSWORD=

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# API / host ports: dev uses local URLs; prd uses nginx (see .env.prd)
API_PORT=7400
API_INTERNAL_PORT=4000
API_HOST_PORT=7400
# API server; Next uses `PORT` for its own listen — prd `front-cards` service sets `PORT` from `FRONTEND_PORT` in docker-compose.
PORT=4000
API_URL=https://ecards.aiepic.app
NGINX_HTTP_PORT=80
CORS_ALLOWED_ORIGINS=https://ecards.aiepic.app

# Frontend (ports / Next.js)
FRONTEND_HOST_PORT=7300
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://ecards.aiepic.app
NEXT_PUBLIC_WS_URL=wss://ecards.aiepic.app

# Post-login redirect (path on E-Cards or absolute URL to Tools)
NEXT_PUBLIC_POST_LOGIN_REDIRECT_URL=/dashboard
POST_LOGIN_REDIRECT_URL=/dashboard
OAUTH_REDIRECT_URI=https://ecards.aiepic.app/oauth/complete

# Frontend OAuth (NEXT_PUBLIC_ = browser)
NEXT_PUBLIC_OAUTH_CLIENT_ID=CHANGE_ME_OAUTH_CLIENT_ID
NEXT_PUBLIC_OAUTH_AUTHORIZATION_ENDPOINT=https://tools.aiepic.app/oauth/authorize
NEXT_PUBLIC_OAUTH_TOKEN_ENDPOINT=https://tools.aiepic.app/oauth/token
NEXT_PUBLIC_OAUTH_USER_INFO_ENDPOINT=https://tools.aiepic.app/api/users/me
NEXT_PUBLIC_EXTERNAL_AUTH_URL=https://tools.aiepic.app/app
NEXT_PUBLIC_USER_SUBSCRIPTION_URL=https://tools.aiepic.app/app/features/user-subscription

# Backend OAuth (server-only)
# Production: tools.aiepic.app above. Dev compose: dev.aiepic.app + host-gateway when identity runs on the host.
OAUTH_CLIENT_ID=CHANGE_ME_OAUTH_CLIENT_ID
OAUTH_CLIENT_SECRET=CHANGE_ME_OAUTH_CLIENT_SECRET
OAUTH_AUTHORIZATION_ENDPOINT=https://tools.aiepic.app/oauth/authorize
OAUTH_TOKEN_ENDPOINT=https://tools.aiepic.app/oauth/token
OAUTH_USER_INFO_ENDPOINT=https://tools.aiepic.app/api/users/me
OAUTH_SCOPES=profile email subscription

# JWT
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHAR_RANDOM_SECRET
JWT_EXPIRY=7d

# Rate limiting (api-server)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200

# ============================================================================
# LLM CONFIGURATION (Name Parsing)
# ============================================================================

LLM_ENABLED=true
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=deepseek
LLM_CREDIT_COST=1
LLM_RETRY_ATTEMPTS=2
LLM_TIMEOUT_MS=10000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.3
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=500
ANTHROPIC_TEMPERATURE=0.3
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=500
DEEPSEEK_TEMPERATURE=0.3
EXTERNAL_LLM_API=http://remote-llm-server:5000/api/llm

# ============================================================================
# EXTERNAL SERVICES (Object storage + Tools Dashboard URLs)
# ============================================================================

USE_LOCAL_STORAGE=false
SEAWEEDFS_ENDPOINT=https://seaweed.aiepic.app
SEAWEEDFS_ACCESS_KEY=
SEAWEEDFS_SECRET_KEY=
SEAWEEDFS_BUCKET=ecards-prd
SEAWEEDFS_REGION=us-east-1
EXTERNAL_AUTH_URL=https://tools.aiepic.app/app
EXTERNAL_USER_API=https://tools.aiepic.app/admin/api
EXTERNAL_SUBSCRIPTION_WS=wss://tools.aiepic.app/admin/ws

# ============================================================================
# AUTO-AUTH, SESSION, APP REGISTRATION
# ============================================================================

USER_SUBSCRIPTION_URL=https://tools.aiepic.app/app/features/user-subscription
APPLICATION_ID=CHANGE_ME_APPLICATION_ID
EXTERNAL_API_KEY=CHANGE_ME_EXTERNAL_API_KEY
TOKEN_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SESSION_COOKIE_NAME=ecards_auth
REFRESH_COOKIE_NAME=ecards_refresh
SESSION_COOKIE_MAX_AGE=3600
REFRESH_COOKIE_MAX_AGE=2592000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax
PKCE_ENABLED=true
PKCE_CODE_CHALLENGE_METHOD=S256
OAUTH_STATE_ENABLED=true
AUTH_RATE_LIMIT_LOGIN_WINDOW=900000
AUTH_RATE_LIMIT_LOGIN_MAX=5
AUTH_RATE_LIMIT_CALLBACK_WINDOW=900000
AUTH_RATE_LIMIT_CALLBACK_MAX=10
AUTH_RATE_LIMIT_REFRESH_WINDOW=3600000
AUTH_RATE_LIMIT_REFRESH_MAX=20

# ============================================================================
# WORKER CONFIGURATION
# ============================================================================

WORKER_CONCURRENCY=4
WORKER_MAX_ATTEMPTS=3
WORKER_TIMEOUT=60000
RENDER_ENGINE=canvas

# ============================================================================
# FEATURE FLAGS
# ============================================================================

FEATURE_TEMPLATE_DESIGNER=true
FEATURE_BATCH_IMPORT=true
FEATURE_LLM_NAME_PARSING=true
FEATURE_WEBSOCKET_UPDATES=true

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

LOG_LEVEL=info
DEBUG=
