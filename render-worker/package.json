{
  "name": "@ecards/render-worker",
  "version": "1.0.0",
  "description": "E-Cards background rendering worker",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "tsx watch src/worker.ts",
    "build": "tsc",
    "build:docker": "npx --yes esbuild@0.25.0 src/worker.ts --bundle --platform=node --target=node20 --format=cjs --packages=external --outfile=dist/worker.js",
    "start": "node dist/worker.js",
    "worker": "tsx src/worker.ts",
    "test": "node node_modules/jest/bin/jest.js"
  },
  "keywords": ["ecards", "worker", "rendering"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.1",
    "@aws-sdk/client-s3": "^3.651.0",
    "bullmq": "^5.1.8",
    "ioredis": "^5.3.2",
    "canvas": "^2.11.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  }
}
