{
  "name": "@ecards/api-server",
  "version": "0.5.1",
  "description": "E-Cards internal API server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node -r ./scripts/preload-root-env.cjs node_modules/prisma/build/index.js generate && node -r ./scripts/preload-root-env.cjs node_modules/prisma/build/index.js db push && tsx watch src/server.ts",
    "dev:server": "tsx watch src/server.ts",
    "build": "tsc",
    "build:docker": "npx --yes esbuild@0.25.0 src/server.ts --bundle --platform=node --target=node20 --format=cjs --packages=external --outfile=dist/server.js",
    "start": "node dist/server.js",
    "test": "NODE_OPTIONS='--max-old-space-size=460' node scripts/run-tests.cjs",
    "db:push": "node -r ./scripts/preload-root-env.cjs node_modules/prisma/build/index.js db push",
    "db:migrate": "node -r ./scripts/preload-root-env.cjs node_modules/prisma/build/index.js migrate dev",
    "db:generate": "node -r ./scripts/preload-root-env.cjs node_modules/prisma/build/index.js generate",
    "db:studio": "node -r ./scripts/preload-root-env.cjs node_modules/prisma/build/index.js studio"
  },
  "keywords": [
    "ecards",
    "api",
    "backend"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.651.0",
    "@aws-sdk/lib-storage": "^3.651.0",
    "@aws-sdk/s3-request-presigner": "^3.651.0",
    "@fastify/cookie": "^9.2.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^5.8.1",
    "axios": "^1.13.2",
    "bull": "^4.11.5",
    "bullmq": "^5.1.8",
    "cassandra-driver": "^4.7.2",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "ioredis": "^5.3.2",
    "mime-types": "^2.1.35",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bull": "^4.10.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.8",
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.2",
    "prisma": "^5.8.1",
    "ts-jest": "^29.4.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
